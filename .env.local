# Local dev environment for YoloScribe.
#
# Usage:
#   cp .env.local .env
#   # Fill in ANTHROPIC_API_KEY below, then:
#   docker compose up -d
#   cd frontend && npm install && npm run dev
#
# The backend will be at http://localhost:8000
# The frontend dev server will be at http://localhost:5173
# MinIO console: http://localhost:9001  (user: yoloscribe / pass: yoloscribe)
# ElasticMQ:     http://localhost:9324

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Local mode (bypasses Supabase, IAM, K8s) ─────────────────────────────────
LOCAL_MODE=true
LOCAL_SITE_NAME=local
LOCAL_USER_ID=local-user-00000000

# ── MinIO (local S3) ──────────────────────────────────────────────────────────
S3_BUCKET=yoloscribe
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=yoloscribe
AWS_SECRET_ACCESS_KEY=yoloscribe
AWS_REGION=us-east-1

# ── ElasticMQ (local SQS) ─────────────────────────────────────────────────────
SQS_QUEUE_URL=http://localhost:9324/000000000000/yoloscribe-runner
SQS_INDEXING_QUEUE_URL=http://localhost:9324/000000000000/yoloscribe-indexing
SQS_ENDPOINT_URL=http://localhost:9324

# ── Agent runner ──────────────────────────────────────────────────────────────
LOCAL_RUNNER=true

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# VITE_LOCAL_MODE skips Supabase auth in the browser — the backend accepts all
# requests as the local user when LOCAL_MODE=true.
VITE_LOCAL_MODE=true
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE=http://localhost:8000
VITE_SITE=local
