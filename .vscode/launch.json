{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AgentScribe Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
