ANTHROPIC_API_KEY=sk-ant-...
S3_BUCKET=my-agentscribe-bucket
ALLOWED_ORIGINS=https://my-agentscribe-site.s3-website.amazonaws.com
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/agentscribe-runner

# ── Frontend deploy (infra/deploy_frontend.sh) ────────────────────────────────
VITE_API_BASE=https://agentscribe-dev.runyolo.dev
FRONTEND_BUCKET=my-agentscribe-frontend-bucket
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# CLOUDFRONT_DISTRIBUTION_ID=EXAMPLEID   # optional — invalidates /* after sync
# AGENTSCRIBE_MODEL=claude-opus-4-6   # optional override
GHCR_PAT=ghp_...
GITHUB_USER=your-github-username

# ── Auth & provisioning ───────────────────────────────────────────────────────
# Leave SUPABASE_JWT_SECRET empty to disable JWT auth in dev (user_id="default")
SUPABASE_JWT_SECRET=
WEBHOOK_SECRET=

# ── EKS / K8s (required for /webhooks/user-created) ──────────────────────────
EKS_OIDC_PROVIDER=oidc.eks.us-east-1.amazonaws.com/id/EXAMPLE
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
K8S_NAMESPACE=agentscribe
# Set KUBECONFIG when running locally so the webhook can reach the cluster.
# In-cluster (EKS pod), leave this unset — the service account token is used instead.
# KUBECONFIG=~/.kube/config
