# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_PROFILE=myprofile          # named profile for local dev; omit in production (use IRSA)
AWS_REGION=us-east-1

# ── Agent runner (uv run agent-runner) ────────────────────────────────────────
BUCKET=my-agentscribe-bucket
AGENT_MD_KEY=knuth/.agents/my-agent/agent.md
CONTENT_KEY=knuth/content.md
PROMPT=Update the page with the latest information.
USER_ID=knuth
ANTHROPIC_API_KEY=sk-ant-...
AGENTSCRIBE_MODEL=claude-opus-4-6   # optional; default is claude-opus-4-6

# ── Polling worker (uv run polling-worker) ────────────────────────────────────
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/agentscribe-jobs
AGENT_RUNNER_IMAGE=ghcr.io/nate-yolodev/agentscribe-agent-runner:latest
ANTHROPIC_SECRET_NAME=agentscribe-secrets   # K8s Secret name (not used in LOCAL_RUNNER mode)
K8S_NAMESPACE=agentscribe

# Set LOCAL_RUNNER=true to run agents as local subprocesses instead of K8s Jobs.
# Useful for local development and testing without a Kubernetes cluster.
LOCAL_RUNNER=true
