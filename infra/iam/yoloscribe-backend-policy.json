{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::yoloscribe-*",
        "arn:aws:s3:::yoloscribe-*/*"
      ]
    },
    {
      "Sid": "SecretsManagerReadWrite",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:CreateSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": "arn:aws:secretsmanager:*:*:secret:yoloscribe*"
    },
    {
      "Sid": "IAMProvisionUserRoles",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:PutRolePolicy",
        "iam:GetRole"
      ],
      "Resource": "arn:aws:iam::*:role/yoloscribe/yoloscribe-user-*"
    },
    {
      "Sid": "SQSSend",
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage"
      ],
      "Resource": "arn:aws:sqs:*:*:yoloscribe-*"
    },
    {
      "Sid": "BedrockEmbed",
      "Effect": "Allow",
      "Action": "bedrock:InvokeModel",
      "Resource": "arn:aws:bedrock:*::foundation-model/*"
    },
    {
      "Sid": "S3VectorsQuery",
      "Effect": "Allow",
      "Action": "s3vectors:QueryVectors",
      "Resource": "arn:aws:s3vectors:*:*:bucket/*/index/*"
    }
  ]
}
