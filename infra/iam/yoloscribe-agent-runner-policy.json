{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SQSPoll",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": "arn:aws:sqs:*:*:yoloscribe-*"
    },
    {
      "Sid": "S3ReadAgentDefs",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::yoloscribe-*",
        "arn:aws:s3:::yoloscribe-*/*"
      ]
    }
  ]
}
