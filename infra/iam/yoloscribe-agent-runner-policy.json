{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SQSPoll",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": "arn:aws:sqs:*:*:yoloscribe-*"
    },
    {
      "Sid": "S3ReadAgentDefs",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::yoloscribe-*",
        "arn:aws:s3:::yoloscribe-*/*"
      ]
    },
    {
      "Sid": "S3WriteAgentRunnerOutputs",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": [
        "arn:aws:s3:::yoloscribe-*/*/.agents/*/runs/*",
        "arn:aws:s3:::yoloscribe-*/*/.user/librarian/*",
        "arn:aws:s3:::yoloscribe-*/*/.user/notifications.md"
      ]
    },
    {
      "Sid": "SMReadUserWebhooks",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:*:*:secret:yoloscribe/*/webhooks*"
    },
    {
      "Sid": "DynamoDBAgentLocks",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:DeleteItem",
        "dynamodb:Scan"
      ],
      "Resource": "arn:aws:dynamodb:*:*:table/yoloscribe-agent-locks"
    }
  ]
}
