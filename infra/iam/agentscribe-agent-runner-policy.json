{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SQSPoll",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": "arn:aws:sqs:*:*:agentscribe-*"
    },
    {
      "Sid": "S3ReadAgentDefs",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::agentscribe-*",
        "arn:aws:s3:::agentscribe-*/*"
      ]
    }
  ]
}
