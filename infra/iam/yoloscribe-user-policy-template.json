{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManagerReadUserSecrets",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:*:*:secret:yoloscribe/${USER_ID}/*"
    },
    {
      "Sid": "S3ReadWriteUserPrefix",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::${BUCKET}/${USER_ID}/*"
    },
    {
      "Sid": "S3ListUserPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::${BUCKET}",
      "Condition": {
        "StringLike": {"s3:prefix": "${USER_ID}/*"}
      }
    },
    {
      "Sid": "SQSSendAgentQueue",
      "Effect": "Allow",
      "Action": "sqs:SendMessage",
      "Resource": "${SQS_QUEUE_ARN}"
    },
    {
      "Sid": "SQSSendIndexingQueue",
      "Effect": "Allow",
      "Action": "sqs:SendMessage",
      "Resource": "${SQS_INDEXING_QUEUE_ARN}"
    },
    {
      "Sid": "DynamoDBAgentLocksUserScoped",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:*:*:table/yoloscribe-agent-locks",
      "Condition": {
        "ForAllValues:StringEquals": {
          "dynamodb:LeadingKeys": ["${USER_ID}"]
        }
      }
    }
  ]
}
