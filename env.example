# Copy this file to .env and fill in values for your environment.
# All scripts and dev commands load .env from the project root.

# ── Backend (FastAPI process) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
S3_BUCKET=my-yoloscribe-bucket
ALLOWED_ORIGINS=https://my-cloudfront-url.cloudfront.net
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/yoloscribe-runner
SQS_INDEXING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/yoloscribe-indexing
# OAUTH_REDIRECT_URI defaults to http://localhost:8000/oauth/callback for local dev (RFC 8252).
# In production it is derived automatically from ingress.host in the Helm chart.
# OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback

# FRONTEND_URL defaults to http://localhost:5173 for local dev (Vite dev server).
# In production it is derived automatically from CLOUDFRONT_DOMAIN.
# FRONTEND_URL=http://localhost:5173
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service role key — used for admin API calls (provision endpoint)
WEBHOOK_SECRET=
# YOLOSCRIBE_MODEL=sonnet             # optional — global model key fallback (haiku|sonnet|opus|bedrock-*)
# YOLOSCRIBE_CHAT_MODEL=sonnet        # optional — ChatAgent (orchestrator) model key
# YOLOSCRIBE_WRITER_MODEL=haiku       # optional — ContentWriterAgent model key (default: haiku)
# YOLOSCRIBE_CREATOR_MODEL=sonnet     # optional — CreatorAgent / PageCreatorAgent model key
# YOLOSCRIBE_RUNNER_MODEL=sonnet      # optional — agent-runner default (when agent.md has no ## Model)
# LOG_LEVEL=INFO                      # optional — root log level (DEBUG|INFO|WARNING|ERROR); default: INFO
# AWS_PROFILE=myprofile               # optional — named AWS profile for boto3
# KUBECONFIG=~/.kube/config           # optional — local kubeconfig for webhook handler

# ── Frontend (Vite build-time vars) ──────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_BASE=https://your-backend-domain.example.com
# VITE_SITE is the site name used in dev (defaults to "default") and the S3
# deploy prefix used by infra/deploy_frontend.sh.
VITE_SITE=default
# VITE_MARKETING_SITE_URL is shown in the expired invite link error page.
# Defaults to https://yoloscribe.com if not set.
# VITE_MARKETING_SITE_URL=https://yoloscribe.com

# ── Deploy & infra ────────────────────────────────────────────────────────────
# Stage and region select the environment-specific values file for Helm installs.
# e.g. backend.dev.us-west-2.values.yaml, agent-runner.dev.us-west-2.values.yaml
STAGE=dev
REGION=us-west-2

# GitHub Container Registry — used by install_backend.sh and install_runner.sh
GHCR_PAT=ghp_...
GITHUB_USER=your-github-username

# Frontend deploy (infra/deploy_frontend.sh)
FRONTEND_BUCKET=my-yoloscribe-frontend-bucket
# CLOUDFRONT_DISTRIBUTION_ID=EXAMPLEID   # optional — invalidates /* after sync
CLOUDFRONT_DOMAIN=your-distribution-id.cloudfront.net   # used by /provision to build site_url

# EKS / K8s — used by Helm installs and the /webhooks/user-created handler
EKS_OIDC_PROVIDER=oidc.eks.us-east-1.amazonaws.com/id/EXAMPLE
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
K8S_NAMESPACE=yoloscribe

# IAM role for the agent-runner worker.
# Created by infra/iam/create_agent_runner_role.sh; passed to install_runner.sh.
AGENT_RUNNER_ROLE_ARN=arn:aws:iam::123456789012:role/yoloscribe-agent-runner

# ── Indexing (S3 Vectors + Bedrock) ──────────────────────────────────────────
# S3 Vectors bucket and index for semantic search.
S3_VECTORS_BUCKET=my-yoloscribe-vectors
S3_VECTORS_INDEX_NAME=yoloscribe
# Bedrock embedding model ID (1024-dim Titan v2 by default).
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# IAM role for the indexer (polling worker + indexer jobs).
# Created by infra/iam/create_indexer_role.sh; passed to install_indexer.sh.
INDEXER_ROLE_ARN=arn:aws:iam::123456789012:role/yoloscribe-indexer


# ── Local dev mode (Docker Compose / no-AWS) ─────────────────────────────────
# See .env.local for a pre-filled template and INSTALL.md for instructions.
# LOCAL_MODE=true                      # bypass Supabase auth, IAM/K8s, Secrets Manager
# LOCAL_SITE_NAME=local                # site name used in local mode
# LOCAL_USER_ID=local-user-00000000    # user ID used in local mode
# LOCAL_MCP_API_KEY=local              # static Bearer token for MCP server in local mode (default: "local")
# S3_ENDPOINT_URL=http://localhost:9000 # MinIO (local S3)
# SQS_ENDPOINT_URL=http://localhost:9324 # ElasticMQ (local SQS)
# LOCAL_RUNNER=true                    # run indexer inline (no K8s)

# ── Discord bot ───────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal (https://discord.com/developers/applications).
DISCORD_BOT_TOKEN=your-discord-bot-token

# Base64-encoded 32-byte AES key used to encrypt API tokens in discord_configs.
# Generate with: python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
DISCORD_AES_KEY=base64-encoded-32-byte-key

# URL of the YoloScribe backend API that the Discord bot will POST /chat to.
YOLOSCRIBE_API_URL=https://yoloscribe-dev.runyolo.dev

# -- Multimedia support
# The cloudfront domain serving up the multimedia content (can be the same as the domain serving up the app) 
# CLOUDFRONT_MEDIA_DOMAIN=cloudfront-domain
# CLOUDFRONT_SIGNING_KEY_ID=cloundfront-public-key-id
